# ============================================================
# Configuración del Sistema de Pases de Día - Camping
# ============================================================

# Entorno: development | production
NODE_ENV=development

# Puerto del servidor
PORT=3000

# Clave secreta para firmar sesiones (cambia esto en producción)
SESSION_SECRET=cambia-esto-por-una-clave-secreta-muy-larga-y-aleatoria

# ------------------------------------------------------------
# Base de datos MongoDB Atlas (connection string)
# En Vercel, define esta variable en el dashboard del proyecto.
# ------------------------------------------------------------
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/?appName=app
MONGODB_DB_NAME=poza_blanca

# ------------------------------------------------------------
# Credenciales del administrador inicial (seed)
# Se crea solo la primera vez que se inicia la base de datos
# ------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_NAME=Recepción

# ------------------------------------------------------------
# Configuración SMTP para envío de correos
# Ejemplo para Gmail: smtp.gmail.com, puerto 465, secure=true
# Usa una "contraseña de aplicación" si usas Gmail con 2FA
# ------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=lapazpozablanca@outlook.es
SMTP_PASS=tu-contrasena-de-aplicacion

# Remitente que aparecerá en los correos enviados
SMTP_FROM_NAME=Poza Blanca Lodge - Recepcion
SMTP_FROM_ADDRESS=lapazpozablanca@outlook.es

# URL pública del sistema (para enlaces en correos)
APP_URL=https://www.pozablancalodge.com

# ------------------------------------------------------------
# Configuración operativa
# ------------------------------------------------------------
# Zona horaria para cálculo de "hoy" (default: America/Costa_Rica)
APP_TIMEZONE=America/Costa_Rica

# Nivel de logs: trace | debug | info | warn | error (default: info en prod, debug en dev)
# LOG_LEVEL=info

# Limite global de requests por IP cada 15 min (default: 300)
# RATE_LIMIT_MAX=300
