<!DOCTYPE html>
<html lang="es" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title><%= typeof title !== 'undefined' ? title + ' · ' : '' %>Poza Blanca Lodge</title>
  <meta name="description" content="Sistema de pases de día — Poza Blanca Lodge, San Mateo, Alajuela, Costa Rica" />
  <link rel="icon" type="image/png" href="/assets/favicon.png" />
  <script>
    (function () {
      try {
        var m = document.cookie.match(/(?:^|;)\s*theme=([^;]+)/);
        var t = m ? decodeURIComponent(m[1]) : (localStorage.getItem('poza-theme') || 'light');
        if (t === 'dark') document.documentElement.classList.add('dark');
        else document.documentElement.classList.remove('dark');
      } catch (e) {}
    })();
  </script>
  <style id="poza-critical">
    html { font-size: 16px !important; scroll-behavior: smooth; -webkit-text-size-adjust: none !important; text-size-adjust: none !important; }
    *, *::before, *::after { -webkit-text-size-adjust: none !important; text-size-adjust: none !important; -webkit-font-smoothing: antialiased; }
    html, body { margin: 0; padding: 0; }
    body { font-family: 'Inter', system-ui, sans-serif; touch-action: manipulation; }
  </style>
  <script>
    (function () {
      try {
        // Respaldo para evitar que iOS/Safari escalen el texto base por accesibilidad del sistema
        document.documentElement.style.setProperty('font-size', '16px', 'important');
      } catch (e) {}
    })();
  </script>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            transparent: 'transparent',
            current: 'currentColor',
            slate: {
              50:  'rgb(var(--tw-c-slate-50) / <alpha-value>)',
              100: 'rgb(var(--tw-c-slate-100) / <alpha-value>)',
              200: 'rgb(var(--tw-c-slate-200) / <alpha-value>)',
              300: 'rgb(var(--tw-c-slate-300) / <alpha-value>)',
              400: 'rgb(var(--tw-c-slate-400) / <alpha-value>)',
              500: 'rgb(var(--tw-c-slate-500) / <alpha-value>)',
              600: 'rgb(var(--tw-c-slate-600) / <alpha-value>)',
              700: 'rgb(var(--tw-c-slate-700) / <alpha-value>)',
              800: 'rgb(var(--tw-c-slate-800) / <alpha-value>)',
              900: 'rgb(var(--tw-c-slate-900) / <alpha-value>)',
              950: 'rgb(var(--tw-c-slate-950) / <alpha-value>)',
            },
            poza: {
              50:  'rgb(var(--tw-c-poza-50) / <alpha-value>)',
              100: 'rgb(var(--tw-c-poza-100) / <alpha-value>)',
              200: 'rgb(var(--tw-c-poza-200) / <alpha-value>)',
              300: 'rgb(var(--tw-c-poza-300) / <alpha-value>)',
              400: 'rgb(var(--tw-c-poza-400) / <alpha-value>)',
              500: 'rgb(var(--tw-c-poza-500) / <alpha-value>)',
              600: 'rgb(var(--tw-c-poza-600) / <alpha-value>)',
              700: 'rgb(var(--tw-c-poza-700) / <alpha-value>)',
              800: 'rgb(var(--tw-c-poza-800) / <alpha-value>)',
              900: 'rgb(var(--tw-c-poza-900) / <alpha-value>)',
              950: 'rgb(var(--tw-c-poza-950) / <alpha-value>)',
            },
            sand: {
              50:  'rgb(var(--tw-c-sand-50) / <alpha-value>)',
              100: 'rgb(var(--tw-c-sand-100) / <alpha-value>)',
              200: 'rgb(var(--tw-c-sand-200) / <alpha-value>)',
              300: 'rgb(var(--tw-c-sand-300) / <alpha-value>)',
            },
            gold: {
              50:  'rgb(var(--tw-c-gold-50) / <alpha-value>)',
              100: 'rgb(var(--tw-c-gold-100) / <alpha-value>)',
              400: 'rgb(var(--tw-c-gold-400) / <alpha-value>)',
              500: 'rgb(var(--tw-c-gold-500) / <alpha-value>)',
            },
            amber: {
              50:  'rgb(var(--tw-c-amber-50) / <alpha-value>)',
              100: 'rgb(var(--tw-c-amber-100) / <alpha-value>)',
              200: 'rgb(var(--tw-c-amber-200) / <alpha-value>)',
              600: 'rgb(var(--tw-c-amber-600) / <alpha-value>)',
              700: 'rgb(var(--tw-c-amber-700) / <alpha-value>)',
              800: 'rgb(var(--tw-c-amber-800) / <alpha-value>)',
              900: 'rgb(var(--tw-c-amber-900) / <alpha-value>)',
            },
            red: {
              50:  'rgb(var(--tw-c-red-50) / <alpha-value>)',
              100: 'rgb(var(--tw-c-red-100) / <alpha-value>)',
              200: 'rgb(var(--tw-c-red-200) / <alpha-value>)',
              600: 'rgb(var(--tw-c-red-600) / <alpha-value>)',
            },
          },
          fontFamily: { sans: ['Inter','system-ui','sans-serif'], display: ['Cormorant Garamond','Georgia','serif'] },
        },
      },
    };
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Cormorant+Garamond:wght@500;600;700&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Cormorant+Garamond:wght@500;600;700&display=swap" />
  <link rel="stylesheet" href="/css/poza.css?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : '1' %>" />
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <% if (typeof extraHead !== 'undefined') { %><%- extraHead %><% } %>
</head>
<body class="h-full mesh-bg font-sans text-slate-800 antialiased">
  <div class="min-h-full lg:pl-60 flex flex-col">

    <%- include('partials/sidebar', { active: typeof active !== 'undefined' ? active : null, currentUser: typeof currentUser !== 'undefined' ? currentUser : null }) %>

    <header class="sticky top-0 z-20 flex h-14 items-center gap-2 border-b border-slate-200/70 bg-white/75 backdrop-blur-xl px-3 lg:px-6">
      <button type="button" onclick="toggleSidebar()" aria-label="Abrir menú" class="lg:hidden inline-flex h-9 w-9 sm:h-10 sm:w-10 items-center justify-center rounded-lg text-slate-500 hover:bg-slate-100 transition touch-target">
        <svg class="h-[18px] w-[18px] sm:h-5 sm:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
      </button>
      <div class="flex-1 min-w-0">
        <h1 class="truncate text-[14px] sm:text-[16px] font-semibold text-slate-900"><%= typeof title !== 'undefined' ? title : '' %></h1>
      </div>
      <div class="flex items-center gap-2">
        <button type="button" id="theme-toggle" title="Cambiar tema" aria-label="Cambiar tema" class="inline-flex h-9 w-9 sm:h-10 sm:w-10 items-center justify-center rounded-lg text-slate-500 hover:bg-slate-100 transition touch-target">
          <svg class="h-[18px] w-[18px] sm:h-5 sm:w-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>
          <svg class="h-[18px] w-[18px] sm:h-5 sm:w-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"/></svg>
        </button>
        <a href="/pases/nuevo" class="btn-poza inline-flex items-center gap-1.5 text-[12px] sm:text-[13px] whitespace-nowrap">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
          <span class="hidden sm:inline">Nuevo pase</span>
          <span class="sm:hidden">Nuevo</span>
        </a>
      </div>
    </header>

    <main class="flex-1 px-3 py-4 lg:px-6 lg:py-5">
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="mb-4 flex items-start gap-2.5 rounded-xl border border-poza-200 bg-poza-50/80 px-3 py-2.5 text-sm text-poza-800 animate-in">
          <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-poza-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <p class="flex-1 text-sm"><%= success %></p>
          <button onclick="this.parentElement.remove()" class="text-poza-400 hover:text-poza-700"><svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
        </div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="mb-4 flex items-start gap-2.5 rounded-xl border border-red-200 bg-red-50/80 px-3 py-2.5 text-sm text-red-800 animate-in">
          <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>
          <p class="flex-1 text-sm"><%= error %></p>
          <button onclick="this.parentElement.remove()" class="text-red-400 hover:text-red-600"><svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
        </div>
      <% } %>
      <% if (typeof info !== 'undefined' && info) { %>
        <div class="mb-4 flex items-start gap-2.5 rounded-xl border border-amber-200 bg-amber-50/80 px-3 py-2.5 text-sm text-amber-800 animate-in">
          <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.852l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/></svg>
          <p class="flex-1 text-sm"><%= info %></p>
          <button onclick="this.parentElement.remove()" class="text-amber-400 hover:text-amber-600"><svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
        </div>
      <% } %>

      <%- body %>
    </main>


  </div>

  <div id="toast-stack" class="fixed bottom-4 right-4 z-50 flex w-80 max-w-[calc(100vw-2rem)] flex-col gap-2"></div>

  <!-- Modal de confirmación -->
  <div id="confirm-modal" class="fixed inset-0 z-[60] hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm transition-opacity" onclick="closeConfirmModal()"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto">
      <div class="flex min-h-full items-center justify-center p-4 text-center">
        <div class="relative w-full max-w-sm transform overflow-hidden rounded-2xl bg-white text-left shadow-2xl transition-all dark:bg-slate-900">
          <div class="px-5 py-5">
            <div class="flex flex-col items-center text-center sm:flex-row sm:items-start sm:text-left">
              <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-red-100 dark:bg-red-900/30">
                <svg class="h-6 w-6 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                </svg>
              </div>
              <div class="mt-3 sm:ml-4 sm:mt-0">
                <h3 class="text-base font-semibold text-slate-900 dark:text-white" id="modal-title">¿Eliminar pase?</h3>
                <p class="mt-1 text-sm text-slate-500 dark:text-slate-400" id="modal-message">¿Realmente deseas eliminar este pase? Esta acción no se puede deshacer.</p>
              </div>
            </div>
          </div>
          <div class="flex flex-col-reverse gap-2 border-t border-slate-100 bg-slate-50 px-5 py-3 sm:flex-row sm:justify-end dark:border-slate-800 dark:bg-slate-900/50">
            <button type="button" onclick="closeConfirmModal()" class="inline-flex w-full items-center justify-center rounded-lg bg-white px-3 py-2 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50 sm:w-auto dark:bg-slate-800 dark:text-white dark:ring-slate-700">Cancelar</button>
            <button type="button" id="modal-confirm" class="inline-flex w-full items-center justify-center rounded-lg bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500 sm:w-auto">Eliminar</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    function toggleSidebar() {
      const sb = document.getElementById('sidebar');
      const bd = document.getElementById('sidebar-backdrop');
      const isOpen = sb.classList.contains('-translate-x-full');
      sb.classList.toggle('-translate-x-full');
      if (bd) bd.classList.toggle('hidden');
      sb.setAttribute('aria-expanded', String(isOpen));
    }
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        const sb = document.getElementById('sidebar');
        const bd = document.getElementById('sidebar-backdrop');
        if (sb && !sb.classList.contains('-translate-x-full')) {
          sb.classList.add('-translate-x-full');
          if (bd) bd.classList.add('hidden');
          sb.setAttribute('aria-expanded', 'false');
        }
      }
    });

    (function () {
      var btn = document.getElementById('theme-toggle');
      if (btn) {
        btn.addEventListener('click', function () {
          var isDark = document.documentElement.classList.toggle('dark');
          var theme = isDark ? 'dark' : 'light';
          try { localStorage.setItem('poza-theme', theme); } catch (e) {}
          document.cookie = 'theme=' + encodeURIComponent(theme) + ';path=/;max-age=' + (60*60*24*365) + ';samesite=lax';
        });
      }
    })();
  </script>

  <script>
    (function () {
      var confirmModal = document.getElementById('confirm-modal');
      var confirmMessage = document.getElementById('modal-message');
      var confirmBtn = document.getElementById('modal-confirm');
      var activeForm = null;

      window.openConfirmModal = function (form, message) {
        activeForm = form || null;
        if (confirmMessage && message) confirmMessage.textContent = message;
        if (confirmModal) confirmModal.classList.remove('hidden');
      };

      window.closeConfirmModal = function () {
        activeForm = null;
        if (confirmModal) confirmModal.classList.add('hidden');
      };

      if (confirmBtn) {
        confirmBtn.addEventListener('click', function () {
          if (activeForm) activeForm.submit();
          closeConfirmModal();
        });
      }

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeConfirmModal();
      });
    })();
  </script>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    (function () {
      if (typeof io === 'undefined') return;
      var socket = io({ transports: ['websocket', 'polling'] });
      var stack = document.getElementById('toast-stack');

      function toast(kind, title, body) {
        if (!stack) return;
        var el = document.createElement('div');
        var color = kind === 'success' ? 'border-poza-200 bg-poza-50 text-poza-800'
                  : kind === 'warning' ? 'border-amber-200 bg-amber-50 text-amber-800'
                  : 'border-slate-200 bg-white text-slate-800';
        el.className = 'flex items-start gap-2.5 rounded-xl border px-3 py-2.5 text-sm shadow-lg animate-in ' + color;
        el.innerHTML = '<div class="flex-1"><p class="font-semibold text-[13px]">' + title + '</p>' + (body ? '<p class="text-[12px] opacity-80">' + body + '</p>' : '') + '</div><button class="opacity-50 hover:opacity-100">&times;</button>';
        el.querySelector('button').addEventListener('click', function () { el.remove(); });
        stack.appendChild(el);
        setTimeout(function () { if (el.parentNode) el.remove(); }, 6000);
      }

      socket.on('pass:change', function (data) {
        var p = data && data.pass || {};
        var label = data.action === 'create' ? 'Nuevo pase registrado'
                  : data.action === 'update' ? 'Pase actualizado'
                  : data.action === 'delete' ? 'Pase eliminado' : 'Cambio de pase';
        if (data.action === 'delete') {
          toast('info', label, '#' + (p.id || ''));
        } else {
          toast('success', label, (p.nombre || '') + (p.fecha ? ' · ' + p.fecha : ''));
        }
      });

      socket.on('payment:pending', function (data) {
        var p = data && data.pass || {};
        toast('warning', 'Pago pendiente', (p.nombre || '') + (p.monto != null ? ' · ₡' + p.monto : ''));
      });
    })();
  </script>
  <% if (typeof extraScripts !== 'undefined') { %><%- extraScripts %><% } %>
</body>
</html>
