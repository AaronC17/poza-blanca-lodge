<%
  const fmtCRC = typeof formatCRC === 'function' ? formatCRC : (v) => new Intl.NumberFormat('es-CR', { style:'currency', currency:'CRC', minimumFractionDigits:0, maximumFractionDigits:0 }).format(v||0);
  const fmtNum = (v) => new Intl.NumberFormat('es-CR').format(v||0);
  const estadoClass = (e) => e === 'pagado' ? 'badge-paid' : 'badge-pending';
  const estadoLabel = (e) => e === 'pagado' ? 'Pagado' : 'Pendiente';
  const t = report.totals;
  const tipoPaseLabels = { rio: 'Río', camping: 'Camping', rancho: 'Rancho', piscina: 'Piscina', parqueo: 'Parqueo' };
  const tipoPaseColors = { 
    rio: 'bg-green-100 text-green-700', 
    camping: 'bg-yellow-100 text-yellow-700', 
    rancho: 'bg-blue-100 text-blue-700', 
    piscina: 'bg-red-100 text-red-700', 
    parqueo: 'bg-slate-100 text-slate-600' 
  };
  const formaPagoLabels = { efectivo: 'Efectivo', sinpe: 'Sinpe', tarjeta: 'Tarjeta' };
%>

<div class="space-y-4">
  <!-- Header + filtros -->
  <div class="card-3d p-4 animate-in">
    <div class="mb-4 flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 class="text-base font-semibold text-slate-900">Reporte de ingresos</h2>
        <p class="text-xs text-slate-500">Resumen de pases registrados en el período seleccionado.</p>
      </div>
      <a href="/reportes/exportar.pdf?fechaDesde=<%= fechaDesde %>&fechaHasta=<%= fechaHasta %>" class="btn-poza inline-flex items-center justify-center gap-1.5 text-xs">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
        Exportar PDF
      </a>
    </div>

    <form method="GET" action="/reportes" class="flex flex-col gap-3 sm:flex-row sm:items-end">
      <div class="grid grid-cols-2 gap-3 sm:w-80">
        <div>
          <label class="block text-[10px] font-medium text-slate-500 mb-1">Desde</label>
          <input type="date" name="fechaDesde" value="<%= fechaDesde %>" class="input-poza block w-full" />
        </div>
        <div>
          <label class="block text-[10px] font-medium text-slate-500 mb-1">Hasta</label>
          <input type="date" name="fechaHasta" value="<%= fechaHasta %>" class="input-poza block w-full" />
        </div>
      </div>
      <button type="submit" class="inline-flex items-center justify-center gap-1.5 rounded-lg bg-poza-800 px-4 py-2.5 text-xs font-semibold text-white hover:bg-poza-900 transition min-h-[40px]">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z"/></svg>
        Generar
      </button>
    </form>
  </div>

  <!-- KPIs -->
  <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
    <div class="card-3d p-4 animate-in-delay-1">
      <p class="text-xs font-medium text-slate-500">Total pases</p>
      <p class="mt-1 text-xl sm:text-2xl font-bold text-slate-900"><%= fmtNum(t.totalPases) %></p>
    </div>
    <div class="card-3d p-4 animate-in-delay-2">
      <p class="text-xs font-medium text-slate-500">Personas</p>
      <p class="mt-1 text-xl sm:text-2xl font-bold text-slate-900"><%= fmtNum(t.totalPersonas) %></p>
    </div>
    <div class="card-3d p-4 animate-in-delay-3">
      <p class="text-xs font-medium text-slate-500">Ingresos</p>
      <p class="mt-1 text-xl font-bold text-poza-700"><%= fmtCRC(t.montoTotal) %></p>
    </div>
    <div class="card-3d p-4 animate-in-delay-4">
      <p class="text-xs font-medium text-slate-500">Pendiente</p>
      <p class="mt-1 text-xl font-bold text-amber-600"><%= fmtCRC(t.montoPendiente) %></p>
    </div>
  </div>

  <!-- Resumen por día -->
  <% if (report.porDia.length > 0) { %>
  <div class="card-3d p-4 animate-in-delay-2">
    <h3 class="text-sm font-semibold text-slate-900 mb-3">Resumen por día</h3>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-[13px]">
        <thead class="bg-slate-50/80">
          <tr>
            <th class="px-3 py-2 text-left text-[10px] font-semibold uppercase text-slate-500">Fecha</th>
            <th class="px-3 py-2 text-right text-[10px] font-semibold uppercase text-slate-500">Pases</th>
            <th class="px-3 py-2 text-right text-[10px] font-semibold uppercase text-slate-500">Personas</th>
            <th class="px-3 py-2 text-right text-[10px] font-semibold uppercase text-slate-500">Monto</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% report.porDia.forEach(function(d) { %>
            <tr class="row-hover">
              <td class="px-3 py-2 text-slate-700"><%= d.fecha %></td>
              <td class="px-3 py-2 text-right text-slate-700"><%= d.pases %></td>
              <td class="px-3 py-2 text-right text-slate-700"><%= d.personas %></td>
              <td class="px-3 py-2 text-right font-semibold text-poza-700"><%= fmtCRC(d.monto) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>

  <!-- Detalle -->
  <div class="card-3d animate-in-delay-3">
    <div class="flex items-center justify-between border-b border-slate-100 px-4 py-3 no-print">
      <h3 class="text-sm font-semibold text-slate-900">Detalle (<%= report.rows.length %>)</h3>
      <button onclick="window.print()" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-200 px-3 py-2 text-[11px] font-medium text-slate-600 hover:bg-poza-50 hover:text-poza-700 transition min-h-[40px]">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229.685a2.25 2.25 0 01-2.134 3.022 54.365 54.365 0 01-11.51 0 2.25 2.25 0 01-2.134-3.022L6.34 18m11.318 0h-2.408a2.25 2.25 0 00-2.25 2.25M6.34 18H8.748a2.25 2.25 0 012.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18m13.5-9.75h-1.5a1.125 1.125 0 00-1.125 1.125v9.75c0 .621.504 1.125 1.125 1.125H18a1.125 1.125 0 001.125-1.125V10.5A1.125 1.125 0 0018 9.375h-1.5"/></svg>
        Imprimir
      </button>
    </div>
    <% if (report.rows.length === 0) { %>
      <div class="px-4 py-10 text-center text-xs text-slate-400">No hay pases en el rango seleccionado.</div>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50/80">
          <tr>
            <th class="px-4 py-2.5 text-left text-[10px] font-semibold uppercase text-slate-500">Fecha</th>
            <th class="px-4 py-2.5 text-left text-[10px] font-semibold uppercase text-slate-500">Visitante</th>
            <th class="px-4 py-2.5 text-left text-[10px] font-semibold uppercase text-slate-500">Tipo</th>
            <th class="px-4 py-2.5 text-left text-[10px] font-semibold uppercase text-slate-500 hidden sm:table-cell">Ad./Niños</th>
            <th class="px-4 py-2.5 text-left text-[10px] font-semibold uppercase text-slate-500 hidden md:table-cell">Pago</th>
            <th class="px-4 py-2.5 text-right text-[10px] font-semibold uppercase text-slate-500">Monto</th>
            <th class="px-4 py-2.5 text-left text-[10px] font-semibold uppercase text-slate-500">Estado</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white">
          <% report.rows.forEach(function(p) { %>
            <tr class="row-hover">
              <td class="px-4 py-2.5 text-[13px] text-slate-700"><%= p.fecha %></td>
              <td class="px-4 py-2.5 text-[13px] font-medium text-slate-900">
                <%= p.nombre %>
                <p class="text-[10px] text-slate-400 sm:hidden mt-0.5"><%= p.adultos || p.cantidad_personas %> adultos<% if (p.ninos > 0) { %> · <%= p.ninos %> niños<% } %></p>
              </td>
              <td class="px-4 py-2.5">
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold <%= tipoPaseColors[p.tipo_pase] || 'bg-slate-100 text-slate-600' %>">
                  <%= tipoPaseLabels[p.tipo_pase] || '—' %>
                </span>
              </td>
              <td class="px-4 py-2.5 text-[13px] text-slate-700 hidden sm:table-cell"><%= p.adultos || p.cantidad_personas %> / <%= p.ninos || 0 %></td>
              <td class="px-4 py-2.5 text-[11px] text-slate-500 hidden md:table-cell"><%= formaPagoLabels[p.forma_pago] || '—' %></td>
              <td class="px-4 py-2.5 text-[13px] text-right font-semibold text-poza-700"><%= fmtCRC(p.monto) %></td>
              <td class="px-4 py-2.5"><span class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium <%= estadoClass(p.estado_pago) %>"><%= estadoLabel(p.estado_pago) %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>
