<aside id="sidebar" class="sidebar-poza fixed inset-y-0 left-0 z-40 w-60 transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-out text-white flex flex-col">
  <div class="relative z-10 flex flex-col h-full">

    <div class="flex items-center gap-2.5 px-4 py-3.5 border-b border-white/10">
      <img src="/assets/logo.png" alt="Poza Blanca Lodge" class="h-9 w-auto rounded-lg bg-white/95 p-1 shadow-md" />
      <div>
        <p class="font-display text-base font-semibold leading-tight text-white">Poza Blanca</p>
        <p class="text-[10px] uppercase tracking-wider text-poza-300">Lodge · Recepción</p>
      </div>
    </div>

    <nav class="flex-1 px-2.5 py-4 space-y-0.5 overflow-y-auto">
      <p class="px-3 py-1.5 text-[10px] font-semibold uppercase tracking-wider text-poza-300/60">Operación</p>
      <a href="/dashboard" class="nav-link flex items-center gap-2.5 rounded-lg px-3 py-2 text-[13px] font-medium transition-all duration-200 <%= active==='dashboard' ? 'bg-white/12 text-white shadow-sm border border-white/10' : 'text-poza-100/80 hover:bg-white/6 hover:text-white' %>">
        <svg class="h-[18px] w-[18px] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        <span>Panel principal</span>
      </a>
      <a href="/pases" class="nav-link flex items-center gap-2.5 rounded-lg px-3 py-2 text-[13px] font-medium transition-all duration-200 <%= active==='passes' ? 'bg-white/12 text-white shadow-sm border border-white/10' : 'text-poza-100/80 hover:bg-white/6 hover:text-white' %>">
        <svg class="h-[18px] w-[18px] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.244m0 0A15.137 15.137 0 0 1 12 16.5M7.5 4.5h9m-9 0a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 007.5 19.5h9a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0016.5 4.5m-9 0v3m9-3v3"/></svg>
        <span>Pases de día</span>
      </a>
      <a href="/pases/nuevo" class="nav-link flex items-center gap-2.5 rounded-lg px-3 py-2 text-[13px] font-medium transition-all duration-200 <%= active==='new-pass' ? 'bg-white/12 text-white shadow-sm border border-white/10' : 'text-poza-100/80 hover:bg-white/6 hover:text-white' %>">
        <svg class="h-[18px] w-[18px] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        <span>Registrar pase</span>
      </a>

      <p class="px-3 pt-4 pb-1.5 text-[10px] font-semibold uppercase tracking-wider text-poza-300/60">Análisis</p>
      <a href="/reportes" class="nav-link flex items-center gap-2.5 rounded-lg px-3 py-2 text-[13px] font-medium transition-all duration-200 <%= active==='reports' ? 'bg-white/12 text-white shadow-sm border border-white/10' : 'text-poza-100/80 hover:bg-white/6 hover:text-white' %>">
        <svg class="h-[18px] w-[18px] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M18.375 2.25c-1.035 0-1.875.84-1.875 1.875v15.75c0 1.035.84 1.875 1.875 1.875h.75c1.035 0 1.875-.84 1.875-1.875V4.125c0-1.036-.84-1.875-1.875-1.875h-.75zM9.75 8.625c0-1.036.84-1.875 1.875-1.875h.75c1.036 0 1.875.84 1.875 1.875v11.25c0 1.035-.84 1.875-1.875 1.875h-.75a1.875 1.875 0 01-1.875-1.875V8.625zM3 13.125c0-1.036.84-1.875 1.875-1.875h.75c1.036 0 1.875.84 1.875 1.875v6.75c0 1.035-.84 1.875-1.875 1.875h-.75A1.875 1.875 0 013 19.875v-6.75z"/></svg>
        <span>Reportes</span>
      </a>
    </nav>

    <div class="px-2.5 py-3 border-t border-white/10">
      <% if (currentUser) { %>
      <div class="flex items-center gap-2.5 rounded-xl bg-white/5 px-3 py-2 mb-1.5">
        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-poza-400 to-poza-600 text-xs font-bold uppercase shadow-md">
          <%= (currentUser.name || currentUser.username || 'A').charAt(0) %>
        </div>
        <div class="min-w-0 flex-1">
          <p class="truncate text-[13px] font-medium text-white"><%= currentUser.name || currentUser.username %></p>
          <p class="truncate text-[10px] text-poza-300"><%= currentUser.username %></p>
        </div>
      </div>
      <% } %>
      <form method="POST" action="/logout" class="mt-0.5">
        <button type="submit" class="flex w-full items-center gap-2 rounded-lg px-3 py-1.5 text-[13px] text-poza-100/70 hover:bg-white/8 hover:text-white transition">
          <svg class="h-[18px] w-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75"/></svg>
          Cerrar sesión
        </button>
      </form>
    </div>
  </div>
</aside>

<div id="sidebar-backdrop" class="fixed inset-0 z-30 bg-black/45 backdrop-blur-sm lg:hidden hidden" onclick="toggleSidebar()"></div>
