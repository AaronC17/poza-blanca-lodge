<!DOCTYPE html>
<html lang="es" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
  <title>Iniciar sesión · Poza Blanca Lodge</title>
  <link rel="icon" type="image/png" href="/assets/favicon.png" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: { extend: {
        colors: {
          slate: { 50:'rgb(var(--tw-c-slate-50) / <alpha-value>)',100:'rgb(var(--tw-c-slate-100) / <alpha-value>)',200:'rgb(var(--tw-c-slate-200) / <alpha-value>)',300:'rgb(var(--tw-c-slate-300) / <alpha-value>)',400:'rgb(var(--tw-c-slate-400) / <alpha-value>)',500:'rgb(var(--tw-c-slate-500) / <alpha-value>)',600:'rgb(var(--tw-c-slate-600) / <alpha-value>)',700:'rgb(var(--tw-c-slate-700) / <alpha-value>)',800:'rgb(var(--tw-c-slate-800) / <alpha-value>)',900:'rgb(var(--tw-c-slate-900) / <alpha-value>)',950:'rgb(var(--tw-c-slate-950) / <alpha-value>)' },
          poza: { 50:'rgb(var(--tw-c-poza-50) / <alpha-value>)',100:'rgb(var(--tw-c-poza-100) / <alpha-value>)',200:'rgb(var(--tw-c-poza-200) / <alpha-value>)',300:'rgb(var(--tw-c-poza-300) / <alpha-value>)',400:'rgb(var(--tw-c-poza-400) / <alpha-value>)',500:'rgb(var(--tw-c-poza-500) / <alpha-value>)',600:'rgb(var(--tw-c-poza-600) / <alpha-value>)',700:'rgb(var(--tw-c-poza-700) / <alpha-value>)',800:'rgb(var(--tw-c-poza-800) / <alpha-value>)',900:'rgb(var(--tw-c-poza-900) / <alpha-value>)',950:'rgb(var(--tw-c-poza-950) / <alpha-value>)' },
          sand: { 50:'rgb(var(--tw-c-sand-50) / <alpha-value>)',100:'rgb(var(--tw-c-sand-100) / <alpha-value>)',200:'rgb(var(--tw-c-sand-200) / <alpha-value>)',300:'rgb(var(--tw-c-sand-300) / <alpha-value>)' },
          gold: { 50:'rgb(var(--tw-c-gold-50) / <alpha-value>)',100:'rgb(var(--tw-c-gold-100) / <alpha-value>)',400:'rgb(var(--tw-c-gold-400) / <alpha-value>)',500:'rgb(var(--tw-c-gold-500) / <alpha-value>)' },
          amber: { 50:'rgb(var(--tw-c-amber-50) / <alpha-value>)',100:'rgb(var(--tw-c-amber-100) / <alpha-value>)',200:'rgb(var(--tw-c-amber-200) / <alpha-value>)',600:'rgb(var(--tw-c-amber-600) / <alpha-value>)',700:'rgb(var(--tw-c-amber-700) / <alpha-value>)',800:'rgb(var(--tw-c-amber-800) / <alpha-value>)',900:'rgb(var(--tw-c-amber-900) / <alpha-value>)' },
          red: { 50:'rgb(var(--tw-c-red-50) / <alpha-value>)',100:'rgb(var(--tw-c-red-100) / <alpha-value>)',200:'rgb(var(--tw-c-red-200) / <alpha-value>)',600:'rgb(var(--tw-c-red-600) / <alpha-value>)' },
        },
        fontFamily: { sans: ['Inter','system-ui','sans-serif'], display: ['Cormorant Garamond','Georgia','serif'] },
      } },
    };
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Cormorant+Garamond:wght@500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/poza.css?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : '1' %>" />
  <style>
    html { font-size: 110%; }
  </style>
</head>
<body class="h-full font-sans antialiased">
  <div class="flex min-h-full">
    <!-- Panel izquierdo: imagen + branding (50%) -->
    <div class="relative hidden w-1/2 lg:flex">
      <img src="/assets/hero-banner.jpg" alt="Poza Blanca Lodge" class="absolute inset-0 h-full w-full object-cover" />
      <!-- Overlay oscuro para legibilidad del texto sobre la imagen -->
      <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/65 to-black/30"></div>
      <div class="absolute inset-0" style="background: radial-gradient(circle at 28% 18%, rgba(0,0,0,0.25) 0%, transparent 55%);"></div>

      <div class="relative flex h-full w-full flex-col justify-between p-12 text-white text-on-image">
        <!-- Logo -->
        <div class="flex items-center gap-3 animate-in">
          <img src="/assets/logo.png" alt="Poza Blanca Lodge" class="h-11 w-auto rounded-lg bg-white/95 p-1.5" />
          <div>
            <p class="font-display text-xl font-semibold leading-tight">Poza Blanca Lodge</p>
            <p class="text-[10px] uppercase tracking-wider text-poza-300">Hotel Boutique · Costa Rica</p>
          </div>
        </div>

        <!-- Centro: título + características -->
        <div class="max-w-md animate-in-delay-2">
          <span class="divider-leaf text-poza-300 text-xs">Sistema de recepción</span>
          <h2 class="font-display mt-4 text-4xl font-semibold leading-tight">Pases del día</h2>
          <p class="mt-3 text-base leading-relaxed text-poza-100/85">Sistema de recepción, control de ingresos y confirmación por correo.</p>

          <div class="mt-8 space-y-3.5">
            <div class="flex items-center gap-3 text-sm text-poza-100/95">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/15 backdrop-blur border border-white/30 flex-shrink-0">
                <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
              </span>
              Registro rápido de visitantes
            </div>
            <div class="flex items-center gap-3 text-sm text-poza-100/95">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/15 backdrop-blur border border-white/30 flex-shrink-0">
                <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
              </span>
              Confirmación automática por correo
            </div>
            <div class="flex items-center gap-3 text-sm text-poza-100/95">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/15 backdrop-blur border border-white/30 flex-shrink-0">
                <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>
              </span>
              Reportes de ingresos por período
            </div>
          </div>
        </div>

        <p class="text-xs text-poza-300">© <%= new Date().getFullYear() %> Poza Blanca Lodge · San Mateo, Alajuela</p>
      </div>
    </div>

    <!-- Panel derecho: formulario (50%) -->
    <div class="relative flex w-full flex-col justify-center bg-gradient-to-br from-sand-50 via-white to-sand-50 lg:w-1/2">
      <div class="mx-auto w-full max-w-md px-6 py-12 sm:px-10 sm:py-16 lg:py-24 bg-white border border-slate-300/60 rounded-3xl shadow-[0_20px_60px_-15px_rgba(15,23,42,0.18)]">
        <!-- Logo móvil -->
        <div class="lg:hidden mb-8 flex flex-col items-center gap-2 animate-in">
          <img src="/assets/logo.png" alt="Poza Blanca Lodge" class="h-12 w-auto" />
          <div class="text-center">
            <p class="font-display text-xl font-semibold text-poza-800 leading-tight">Poza Blanca Lodge</p>
            <p class="text-[10px] uppercase tracking-wider text-poza-500">Hotel Boutique · Costa Rica</p>
          </div>
        </div>

        <!-- Encabezado centrado -->
        <div class="text-center animate-in-delay-1">
          <h1 class="font-display text-3xl font-semibold text-poza-900 leading-none tracking-tight">Iniciar sesión</h1>
          <p class="mt-2 text-sm text-slate-500">Ingresa tus credenciales para acceder<br class="hidden sm:block" />al panel de recepción.</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="mt-6 flex items-center gap-3 rounded-xl border border-poza-200 bg-gradient-to-r from-poza-50 to-poza-50/40 px-4 py-3.5 animate-in text-left">
            <span class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-lg bg-poza-100 text-poza-600">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
            </span>
            <p class="text-sm font-medium text-poza-800"><%= error %></p>
          </div>
        <% } %>

        <!-- Formulario -->
        <form method="POST" action="/login" class="mt-7 space-y-4 animate-in-delay-2">
          <div>
            <label for="username" class="block text-xs font-semibold text-slate-600 mb-1.5">Usuario</label>
            <div class="relative">
              <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5 text-slate-400">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
              </span>
              <input id="username" name="username" type="text" required autofocus autocomplete="username" class="input-poza block w-full pl-10" placeholder="admin" />
            </div>
          </div>
          <div>
            <label for="password" class="block text-xs font-semibold text-slate-600 mb-1.5">Contraseña</label>
            <div class="relative">
              <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5 text-slate-400">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
              </span>
              <input id="password" name="password" type="password" required autocomplete="current-password" class="input-poza block w-full pl-10" placeholder="••••••••" />
            </div>
          </div>
          <button type="submit" class="btn-poza flex w-full justify-center items-center gap-2 py-3 text-sm !mt-6">
            <span>Ingresar al panel</span>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </button>
        </form>

        <!-- Footer del panel -->
        <div class="mt-8 flex items-center justify-center gap-2 text-center">
          <span class="h-px flex-1 bg-slate-200 max-w-[60px]"></span>
          <p class="text-[11px] text-slate-400 whitespace-nowrap">Personal autorizado · Recepción</p>
          <span class="h-px flex-1 bg-slate-200 max-w-[60px]"></span>
        </div>
        <p class="mt-4 text-center text-[11px] text-slate-400">Poza Blanca Lodge · San Mateo, Alajuela, Costa Rica</p>
      </div>
    </div>
  </div>
</body>
</html>
