<%
  const fmtCRC = typeof formatCRC === 'function' ? formatCRC : (v) => new Intl.NumberFormat('es-CR', { style:'currency', currency:'CRC', minimumFractionDigits:0, maximumFractionDigits:0 }).format(v||0);
  const estadoClass = pass.estado_pago === 'pagado' ? 'badge-paid' : 'badge-pending';
  const estadoLabel = pass.estado_pago === 'pagado' ? 'Pagado' : 'Pendiente';
  const fechaLabel = new Date(pass.fecha + 'T00:00:00').toLocaleDateString('es-CR', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
  const creadoLabel = new Date(pass.created_at + 'Z').toLocaleString('es-CR', { dateStyle:'medium', timeStyle:'short' });
%>

<div class="mx-auto max-w-2xl">
  <div class="mb-3 flex items-center gap-2 animate-in">
    <a href="/pases" class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-slate-200 bg-white text-slate-500 hover:bg-poza-50 hover:text-poza-700 transition">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
    </a>
    <div>
      <h2 class="font-display text-lg font-semibold text-poza-900 leading-tight">Detalle del pase</h2>
      <p class="text-xs text-slate-500">Información completa del visitante</p>
    </div>
  </div>

  <!-- Cabecera del visitante -->
  <div class="card-3d p-5 animate-in-delay-1 mb-4">
    <div class="flex items-start gap-4">
      <div class="flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-poza-100 to-poza-200 text-lg font-bold text-poza-700 uppercase"><%= (pass.nombre || '?').charAt(0) %></div>
      <div class="flex-1 min-w-0">
        <h3 class="font-display text-xl font-semibold text-slate-900 truncate"><%= pass.nombre %></h3>
        <p class="text-sm text-slate-500">Cédula: <%= pass.cedula %></p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-medium <%= estadoClass %>"><%= estadoLabel %></span>
          <span class="text-[11px] text-slate-400">Creado: <%= creadoLabel %></span>
        </div>
      </div>
      <div class="text-right">
        <p class="text-2xl font-bold text-poza-700"><%= fmtCRC(pass.monto) %></p>
        <p class="text-[11px] text-slate-400"><%= pass.cantidad_personas %> persona(s)</p>
      </div>
    </div>
  </div>

  <!-- Detalle en grid -->
  <div class="card-3d p-5 animate-in-delay-2 mb-4">
    <h4 class="form-section-title mb-3">Información de la visita</h4>
    <dl class="grid grid-cols-1 gap-x-6 gap-y-3 sm:grid-cols-2">
      <div>
        <dt class="text-[11px] font-medium text-slate-500">Fecha</dt>
        <dd class="text-sm font-medium text-slate-900 capitalize"><%= fechaLabel %></dd>
      </div>
      <div class="flex gap-6">
        <div>
          <dt class="text-[11px] font-medium text-slate-500">Entrada</dt>
          <dd class="text-sm font-medium text-slate-900"><%= fmtTime(pass.hora_entrada) || '—' %></dd>
        </div>
        <div>
          <dt class="text-[11px] font-medium text-slate-500">Salida</dt>
          <dd class="text-sm font-medium text-slate-900"><%= fmtTime(pass.hora_salida) || '—' %></dd>
        </div>
      </div>
      <div>
        <dt class="text-[11px] font-medium text-slate-500">Teléfono</dt>
        <dd class="text-sm font-medium text-slate-900"><%= pass.telefono || '—' %></dd>
      </div>
      <div>
        <dt class="text-[11px] font-medium text-slate-500">Correo</dt>
        <dd class="text-sm font-medium text-slate-900 truncate"><%= pass.correo || '—' %></dd>
      </div>
      <div>
        <dt class="text-[11px] font-medium text-slate-500">Cantidad de personas</dt>
        <dd class="text-sm font-medium text-slate-900"><%= pass.cantidad_personas %></dd>
      </div>
      <div>
        <dt class="text-[11px] font-medium text-slate-500">Vehículo (placa)</dt>
        <dd class="text-sm font-medium text-slate-900 uppercase"><%= pass.placa_vehiculo || '—' %></dd>
      </div>
    </dl>
    <% if (pass.observaciones) { %>
    <div class="mt-4 pt-4 border-t border-slate-100">
      <dt class="text-[11px] font-medium text-slate-500 mb-1">Observaciones</dt>
      <dd class="text-sm text-slate-700 bg-sand-50 rounded-lg px-3 py-2.5"><%= pass.observaciones %></dd>
    </div>
    <% } %>
  </div>

  <!-- Acciones -->
  <div class="flex flex-wrap items-center justify-end gap-2 animate-in-delay-3">
    <form method="POST" action="/pases/<%= pass.id %>/reenviar-correo" class="inline">
      <input type="hidden" name="<%= csrfField %>" value="<%= csrfToken %>" />
      <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 bg-white px-4 py-2 text-xs font-medium text-slate-600 hover:bg-slate-50 transition">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
        Reenviar correo
      </button>
    </form>
    <a href="/pases/<%= pass.id %>/editar" class="inline-flex items-center gap-1.5 rounded-lg border border-poza-200 bg-poza-50 px-4 py-2 text-xs font-semibold text-poza-700 hover:bg-poza-100 transition">
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/></svg>
      Editar
    </a>
    <form method="POST" action="/pases/<%= pass.id %>/eliminar" class="inline">
      <input type="hidden" name="<%= csrfField %>" value="<%= csrfToken %>" />
      <input type="hidden" name="redirect" value="/pases?fecha=<%= pass.fecha %>" />
      <button type="button" onclick="openConfirmModal(this.closest('form'), '¿Eliminar este pase? Esta acción no se puede deshacer.')" class="inline-flex items-center gap-1.5 rounded-lg border border-red-200 bg-red-50 px-4 py-2 text-xs font-semibold text-red-600 hover:bg-red-100 transition">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/></svg>
        Eliminar
      </button>
    </form>
  </div>
</div>
