{
  "name": "camping-daypass",
  "version": "1.0.0",
  "description": "Sistema de pases de día para camping - Hotel. Registro automatizado de visitantes, control de ingresos y panel administrativo.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "seed": "node src/db/seed.js",
    "init-db": "node src/db/init.js",
    "backup": "node src/db/backup.js",
    "restore": "node src/db/backup.js restore",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "camping",
    "daypass",
    "hotel",
    "reservas",
    "express"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "connect-sqlite3": "^0.9.16",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "flatpickr": "^4.6.13",
    "helmet": "^8.2.0",
    "method-override": "^3.0.0",
    "morgan": "^1.11.0",
    "nodemailer": "^9.0.1",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.19.1",
    "pino": "^10.3.1",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2"
  }
}
